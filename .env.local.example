# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real secrets.

# ---- Clerk (https://dashboard.clerk.com) ----
# In the Clerk dashboard, create a new application named "RigLogic",
# then grab these from the "API keys" page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional — override default Clerk sign-in/sign-up URLs.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/

# ---- Database (Railway Postgres) ----
# In Railway, create a Postgres service. Copy the `DATABASE_URL` from
# the service's "Variables" tab. Use the "Public Network" URL for local dev,
# the "Private Network" URL for production inside Railway.
DATABASE_URL=

# ---- App ----
# Used for generating absolute URLs in share links, PDF footers, etc.
# Leave blank locally to default to http://localhost:3000.
NEXT_PUBLIC_APP_URL=

# ---- Vercel Blob (crew profile photos + CVs) ----
# In Vercel dashboard → Storage → Create Database → Blob → name it
# "riglogic-crew" → it exposes a `BLOB_READ_WRITE_TOKEN`. Paste below
# locally; for production, Vercel auto-injects it into the project
# environment when you link the Blob store to the Vercel project.
# If this is blank the file-upload endpoints return 503, the rest of
# the app works fine.
BLOB_READ_WRITE_TOKEN=
