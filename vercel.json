{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "regions": [
    "fra1"
  ],
  "github": {
    "silent": true
  },
  "experimentalServices": {
    "web": {
      "routePrefix": "/",
      "framework": "nextjs"
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-stock",
      "schedule": "0 6 * * *"
    }
  ]
}
