// RigLogic — Prisma schema
// Postgres hosted on Railway

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Public shareable kit snapshot. Created when a user clicks "Share" in the
// builder. The payload is a JSON snapshot of the kit so the share link
// renders correctly even if the gear catalog changes later.
model ShareLink {
  id         String   @id @default(cuid())
  shortId    String   @unique // the /s/[shortId] URL segment
  payload    Json     // { projectName, dates, items: [...], notes }
  createdBy  String?  // Clerk userId, nullable in case of guest-mode later
  createdAt  DateTime @default(now())
  viewCount  Int      @default(0)

  @@index([createdAt])
}

// Crew waitlist + Pro tier waitlist email capture.
model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String
  source    String   // "crew" | "pro-tier" | etc.
  createdAt DateTime @default(now())

  @@unique([email, source])
  @@index([source, createdAt])
}

// Public freelancer directory profile. One per Clerk user. Anyone
// with a Clerk account can create their own profile; viewing a
// profile is public. Contact/availability fields are gated behind
// a feature flag (see src/lib/crewGate.ts) so we can flip to
// Pro-only access later without a schema change.
model CrewProfile {
  id                String   @id @default(cuid())
  userId            String   @unique // Clerk userId
  slug              String   @unique // URL-safe, derived from displayName
  displayName       String
  headline          String?  // one-line subhead under the name, e.g. "DP · Dubai"
  bio               String?  @db.Text
  city              String?  // "Dubai", "Abu Dhabi", "Sharjah"…
  roles             String[] // ["DP", "Camera Op", "Steadicam"]
  // Public-ish fields — shown on the profile card
  photoUrl          String?  // Vercel Blob URL, set by /api/crew/upload
  // Private-ish fields — these are what the Pro gate hides later
  email             String?
  phone             String?
  availabilityText  String?  @db.Text
  // CV PDF stored in Vercel Blob
  cvUrl             String?
  cvFileName        String?
  // Portfolio = array of { label, url } objects (e.g. Vimeo, IG, Behance)
  portfolioLinks    Json?    @default("[]")
  // Socials = { instagram, behance, vimeo, youtube, website, imdb }
  socialLinks       Json?    @default("{}")
  // Availability calendar — array of ISO YYYY-MM-DD strings the
  // freelancer has marked as available. Stored as plain strings
  // (not Date) so timezone never shifts a day.
  availableDates    String[] @default([])
  // Opt-in flag for showing the calendar on the public profile.
  // Default off so a freelancer can experiment with marking days
  // without anything appearing publicly until they explicitly
  // flip the switch.
  showAvailabilityCalendar Boolean @default(false)
  // Tier for the future Pro gate. Default free; "pro" flipped by
  // payment or admin action once billing is wired.
  tier              String   @default("free")
  isPublished       Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isPublished, updatedAt])
}
